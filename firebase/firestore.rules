rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() ||
        (isSignedIn() && resource.data.authorId == request.auth.uid);
    }

    match /conversations/{conversationId} {
      function isConversationMember() {
        return isSignedIn() && request.auth.uid in resource.data.memberIds;
      }

      allow get: if isAdmin() || isConversationMember();

      allow list: if isSignedIn();
      
      allow create, update: if isAdmin() ||
        (isSignedIn() && request.auth.uid in request.resource.data.memberIds);
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAdmin() ||
          (isSignedIn() && request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(conversationId)).data.memberIds);

        allow create: if isAdmin() ||
          (isSignedIn() &&
            request.resource.data.senderId == request.auth.uid &&
            request.auth.uid in
              get(/databases/$(database)/documents/conversations/$(conversationId)).data.memberIds);

        allow update, delete: if isAdmin();
      }
    }

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() ||
        (isSignedIn() && resource.data.createdBy == request.auth.uid);

      match /rsvps/{userId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isOwner(userId) || isAdmin();
      }
    }

    match /wellbeingTips/{tipId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /checkIns/{checkInId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /moderationReports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}

{
  "expo": {
    "name": "community-connect-app",
    "slug": "community-connect-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "communityconnectapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.communityconnect.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSCalendarsUsageDescription": "Community Connect uses your calendar to save local events you choose to attend.",
        "NSUserNotificationsUsageDescription": "Community Connect sends reminders for wellbeing check-ins and important community updates."
      }
    },
    "android": {
      "package": "com.communityconnect.app",
      "permissions": [
        "POST_NOTIFICATIONS",
        "READ_CALENDAR",
        "WRITE_CALENDAR",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-calendar",
        {
          "calendarPermission": "Community Connect uses calendar access to add events you RSVP to.",
          "remindersPermission": "Community Connect uses reminders for wellbeing and event follow-ups."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#ffffff",
          "defaultChannel": "default",
          "sounds": [
            "./local/assets/notification_sound.wav",
            "./local/assets/notification_sound_other.wav"
          ],
          "enableBackgroundRemoteNotifications": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "42206f26-12ef-48ab-aa01-3fa3366b5ba1"
      },
      "firebaseApiKey": "",
      "firebaseAuthDomain": "",
      "firebaseProjectId": "",
      "firebaseStorageBucket": "",
      "firebaseMessagingSenderId": "",
      "firebaseAppId": "",
      "router": {}
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
